{
  "name": "x-tweet-tracker-cron",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Cron runner for x-tweet-tracker (calls API only).",
  "engines": {
    "bun": "1.3.11"
  },
  "scripts": {
    "dev": "bun --watch src/cron.ts",
    "build": "bun x tsc -p tsconfig.json",
    "start": "bun src/cron.ts",
    "typecheck": "bun x tsc -p tsconfig.json --noEmit"
  },
  "devDependencies": {
    "@types/bun": "^1.3.11"
  }
}
